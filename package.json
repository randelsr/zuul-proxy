{
  "name": "zuul-proxy",
  "version": "1.0.0",
  "description": "On-chain governance proxy for agent tool access",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:demo": "eslint demo --no-warn-ignored",
    "format": "prettier --write src tests contracts demo",
    "format:check": "prettier --check src tests contracts demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "contracts:build": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:dev": "hardhat node",
    "contracts:deploy:local": "hardhat ignition deploy ignition/modules/Zuul.ts --network localhost",
    "contracts:deploy:hedera": "hardhat ignition deploy ignition/modules/Zuul.ts --network hederaTestnet --parameters ignition/parameters/hedera.json",
    "demo": "tsx demo/scenario.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "hono": "4.0.0",
    "pino": "8.16.0",
    "uuid": "9.0.0",
    "viem": "2.4.0",
    "yaml": "2.3.0",
    "zod": "3.22.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.9",
    "@nomicfoundation/hardhat-ignition": "0.15.0",
    "@nomicfoundation/hardhat-toolbox": "4.0.0",
    "@nomicfoundation/hardhat-viem": "2.0.0",
    "@typechain/hardhat": "9.1.0",
    "@types/node": "22.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "7.0.0",
    "@typescript-eslint/parser": "7.0.0",
    "@vitest/coverage-v8": "1.6.0",
    "eslint": "9.0.0",
    "hardhat": "2.22.0",
    "husky": "9.1.0",
    "lint-staged": "15.2.0",
    "pino-pretty": "11.2.0",
    "prettier": "3.2.0",
    "solidity-coverage": "0.8.5",
    "tsx": "4.7.0",
    "typechain": "8.3.0",
    "typescript": "5.9.2",
    "vitest": "1.6.0"
  }
}
