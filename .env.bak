# ============================================================================
# Zuul Proxy Local Development Configuration
# ============================================================================
# This file is for LOCAL DEVELOPMENT ONLY
# For production, use a secrets management system (Vault, AWS Secrets Manager, etc.)

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
HTTP_ONLY=true

# ============================================================================
# Blockchain Configuration (Local Hardhat)
# ============================================================================
# Make sure Hardhat is running: pnpm contracts:dev
HEDERA_RPC_URL=http://127.0.0.1:8545

# ============================================================================
# Smart Contract Addresses (Local Hardhat)
# ============================================================================
# Deploy contracts first: pnpm hardhat ignition deploy ignition/modules/Zuul.ts --network localhost
# Then copy the contract addresses from the output below

# From: pnpm hardhat run scripts/get-contract-address.ts --network localhost
RBAC_CONTRACT_ADDRESS=0x0165878A594ca255338adfa4d48449f69242Eb8F
AUDIT_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# ============================================================================
# Encryption and Security Keys (Local Testing Only!)
# ============================================================================
# WARNING: These are TEST KEYS for local development ONLY
# For production, use a secrets management system

# Test encryption key (must be 64 hex chars = 32 bytes)
AUDIT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Test wallet private key (Hardhat account #0)
# This is the default Hardhat account used for testing
WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb476c6b8d6c1f02960247590

# ============================================================================
# Tool API Keys (Local Testing - Dummy Values)
# ============================================================================
# These are DUMMY VALUES for local testing
# In production, use real API keys from actual services

GITHUB_API_KEY=test-github-api-key
SLACK_BOT_TOKEN=test-slack-bot-token
OPENAI_API_KEY=test-openai-api-key

# ============================================================================
# Cache and Storage Configuration
# ============================================================================
RBAC_CACHE_TTL_SECONDS=300
NONCE_TTL_SECONDS=300
