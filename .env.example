# ============================================================================
# Zuul Proxy Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment
# NEVER commit .env to version control (it contains secrets)!

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
HTTP_ONLY=true

# ============================================================================
# Blockchain Configuration
# ============================================================================
# For LOCAL DEVELOPMENT (Hardhat):
HEDERA_RPC_URL=http://127.0.0.1:8545

# For HEDERA TESTNET:
# HEDERA_RPC_URL=https://testnet.hashio.io/api/v1/http
# HEDERA_ACCOUNT_ID=0.0.1234567
# HEDERA_PRIVATE_KEY=0x...

# ============================================================================
# Smart Contract Addresses
# ============================================================================
# After deploying contracts, populate these with the deployed addresses

# RBAC contract (source of truth for permissions)
RBAC_CONTRACT_ADDRESS=0x5FbDB2315678afccb333f8a9c21c841F97B39DCd

# Audit contract (immutable blockchain log)
AUDIT_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# ============================================================================
# Encryption and Security Keys
# ============================================================================
# NEVER commit these to version control!

# Audit encryption key (32 bytes in hex = 64 characters)
# Generate with: openssl rand -hex 32
AUDIT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Wallet private key for signing audit entries (EIP-191)
# NEVER share this key!
WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb476c6b8d6c1f02960247590

# ============================================================================
# Tool API Keys
# ============================================================================
# API credentials for upstream services
# NEVER commit actual keys!

GITHUB_API_KEY=ghp_your_github_token_here
SLACK_BOT_TOKEN=xoxb_your_slack_token_here
OPENAI_API_KEY=sk_your_openai_key_here

# ============================================================================
# Cache and Storage Configuration
# ============================================================================
# RBAC permission cache TTL (seconds)
RBAC_CACHE_TTL_SECONDS=300

# Nonce storage TTL (replay attack prevention, seconds)
NONCE_TTL_SECONDS=300

# ============================================================================
# Production Configuration (Optional, for HTTPS)
# ============================================================================
# HTTPS_CERT_PATH=/etc/letsencrypt/live/zuul.example.com/fullchain.pem
# HTTPS_KEY_PATH=/etc/letsencrypt/live/zuul.example.com/privkey.pem
