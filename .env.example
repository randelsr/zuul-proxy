# ============================================================================
# Zuul Proxy Environment Variables
# ============================================================================
# Copy this file to .env and uncomment ONE chain selection block

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ============================================================================
# Chain Selection - UNCOMMENT ONE BLOCK ONLY
# ============================================================================

# --- OPTION 1: HARDHAT LOCAL (Hedera driver) ---
# CHAIN_NAME=hedera
# CHAIN_ID=295
# RPC_URL=http://127.0.0.1:8545
# HARDHAT_SIGNER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- OPTION 2: HARDHAT LOCAL (ADI driver) --- [DEFAULT]
CHAIN_NAME=adi
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
HARDHAT_SIGNER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- OPTION 3: HEDERA TESTNET ---
# CHAIN_NAME=hedera
# CHAIN_ID=296
# RPC_URL=https://testnet.hashio.io/api
# PROXY_SIGNER_KEY=0x_your_hedera_private_key
# HEDERA_ACCOUNT_ID=0.0.123456
# Portal: https://portal.hedera.com (create account & get testnet HBAR)

# --- OPTION 4: ADI TESTNET ---
# CHAIN_NAME=adi
# CHAIN_ID=99999
# RPC_URL=https://rpc.ab.testnet.adifoundation.ai/
# PROXY_SIGNER_KEY=0x_your_adi_private_key
# Faucet: https://faucet.ab.testnet.adifoundation.ai/
# Explorer: https://explorer.ab.testnet.adifoundation.ai/

# ============================================================================
# Smart Contract Addresses
# ============================================================================
# Deploy commands:
#   Local:        pnpm contracts:deploy:local
#   ADI Testnet:  pnpm contracts:deploy:adi
#   Hedera:       pnpm contracts:deploy:hedera

RBAC_CONTRACT_ADDRESS=0x_deployed_rbac_address
AUDIT_CONTRACT_ADDRESS=0x_deployed_audit_address

# ============================================================================
# Audit Encryption
# ============================================================================
# AES-256-GCM key for encrypting audit payloads (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
AUDIT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================================================
# Tool API Keys
# ============================================================================
GITHUB_API_KEY=ghp_your_github_token_here
SLACK_BOT_TOKEN=xoxb-your-slack-token-here
OPENAI_API_KEY=sk-your-openai-key-here
