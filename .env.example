# ============================================================================
# Zuul Proxy Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment
# NEVER commit .env to version control (it contains secrets)!

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ============================================================================
# ADI Chain Configuration (Default Blockchain)
# ============================================================================
# ADI Chain is a UAE institutional L2 (ZKsync-based, EVM-compatible)
# Docs: https://docs.adi.foundation/

# TESTNET (default for development):
ADI_RPC_URL=https://rpc.ab.testnet.adifoundation.ai/
ADI_PRIVATE_KEY=0x_your_private_key_here
# Faucet: https://faucet.ab.testnet.adifoundation.ai/
# Explorer: https://explorer.ab.testnet.adifoundation.ai/

# MAINNET (for production):
# ADI_RPC_URL=https://rpc.adifoundation.ai/
# Explorer: https://explorer.adifoundation.ai/

# LOCAL DEVELOPMENT (Hardhat):
# ADI_RPC_URL=http://127.0.0.1:8545
# HARDHAT_SIGNER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478c6b8d6c1f0296024757059e9

# ============================================================================
# Smart Contract Addresses
# ============================================================================
# After deploying contracts, populate these with the deployed addresses
# Deploy with: pnpm contracts:deploy:adi (testnet) or pnpm contracts:deploy:adi:mainnet

RBAC_CONTRACT_ADDRESS=0x_deployed_rbac_address
AUDIT_CONTRACT_ADDRESS=0x_deployed_audit_address

# ============================================================================
# Proxy Signer Key
# ============================================================================
# Private key for the proxy to sign audit entries and call contracts
# This should be a dedicated key with ADI tokens for gas
PROXY_SIGNER_KEY=0x_your_proxy_signer_key_here

# ============================================================================
# Audit Encryption
# ============================================================================
# AES-256-GCM key for encrypting audit payloads (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
AUDIT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================================================
# Tool API Keys
# ============================================================================
# API credentials for upstream services (injected by proxy)
# NEVER commit actual keys!

GITHUB_API_KEY=ghp_your_github_token_here
SLACK_BOT_TOKEN=xoxb-your-slack-token-here
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# Alternative Chains (Optional)
# ============================================================================
# Hedera Testnet:
# HEDERA_RPC_URL=https://testnet.hashio.io/api
# HEDERA_PRIVATE_KEY=0x...
